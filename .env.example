# Local deployment configuration for pnpm local:deploy
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and will never be committed.

# IP address or hostname of your Home Assistant instance
HA_HOST=homeassistant.local

# SSH port (default: 22)
HA_PORT=22

# SSH username (default: root for Home Assistant OS)
HA_USERNAME=root

# Absolute path to your HA config directory on the remote machine
# Home Assistant OS:       /config
# Docker (common):         /config
# Supervised:              /usr/share/hassio/homeassistant
# Core (venv):             wherever you passed --config
HA_CONFIG_PATH=/config

# Set to true to restart Home Assistant after deploying.
# Uses `ha core restart` via SSH — only works on Home Assistant OS.
# Leave as false and restart manually if you're on a different install type.
HA_RESTART=false
