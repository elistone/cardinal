{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["eslint.config.js", "tsconfig.base.json"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "type-check": {
      "dependsOn": ["^build"]
    },
    "coverage": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "lint": {},
    "verify:bundle": {
      "dependsOn": ["build"],
      "cache": false
    },
    "dev:ha": {
      "cache": false,
      "persistent": true
    },
    "storybook": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "build-storybook": {
      "dependsOn": ["^build"],
      "outputs": ["storybook-static/**"]
    },
    "screenshot": {
      "dependsOn": ["@cardinal/ui#build-storybook"],
      "outputs": ["docs/screenshots/**"],
      "cache": false
    }
  }
}
